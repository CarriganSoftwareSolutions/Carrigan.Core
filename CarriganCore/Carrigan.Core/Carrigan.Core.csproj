<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Description>
      Carrigan.Core is a core library designed to provide essential utilities and infrastructure for other projects. While not intended for standalone use, it serves as a dependency required by other packages to enable key functionality.

      This package contains primarily extension methods, helper methods, base classes, interfaces, data structures, enums, etc which are shared by multiple other packages. It is an internal-use library that supports the architecture of larger projects, ensuring consistency and re-usability across the code base.

      If you are working with other Carrigan Software Solutions projects or components in your solution, Carrigan.Core will be automatically referenced as part of the required dependencies, if it requires this package as a dependency.

      This package is not intended for direct consumption, but if you really want to use my pointless helper methods, feel free.
    </Description>
    <PackageTags>core, utilities, dependency, internal</PackageTags>   

    <!-- Build date is evaluation-time (no target needed) -->
    <BuildDate>$([System.DateTime]::UtcNow.ToString("yyyyMMdd.HHmm"))</BuildDate>

    <!-- Base version: x.y.z -->
    <VersionBase>$(CoreVersionBase)</VersionBase>
    <!-- Default beta release label (empty on Release builds) -->
    <PreReleaseLabel>$(CorePreReleaseLabel)</PreReleaseLabel>

    <!-- Compose the postfix: e.g., -alpha.20250822.2140 -->
    <VersionPostFix Condition="'$(PreReleaseLabel)'!=''">-$(PreReleaseLabel).$(BuildDate)</VersionPostFix>

    <VersionPostFix>-$(PreReleaseLabel).$(BuildDate)-$(GitCommits)</VersionPostFix>

    <!-- Final package/assembly version -->
    <Version>$(VersionBase)$(VersionPostFix)</Version>
    <PackageVersion>$(Version)</PackageVersion>

  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GitInfo" Version="3.5.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
