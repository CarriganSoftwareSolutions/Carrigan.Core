<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Only use the official NuGet v3 feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!-- Optional: disable any other sources that may come from user/machine configs -->
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
